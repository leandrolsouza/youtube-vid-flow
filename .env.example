# Download Behavior
DOWNLOAD_MODE=limited
MAX_CONCURRENT_DOWNLOADS=3
DELETE_FILE_ON_TRASHCAN=false
DEFAULT_OPTION_PLAYLIST_STRICT_MODE=false
DEFAULT_OPTION_PLAYLIST_ITEM_LIMIT=0

# Storage & Directories
DOWNLOAD_DIR=./downloads
AUDIO_DOWNLOAD_DIR=
CUSTOM_DIRS=true
CREATE_CUSTOM_DIRS=true
CUSTOM_DIRS_EXCLUDE_REGEX=(^|/)[.@].*$
DOWNLOAD_DIRS_INDEXABLE=false
STATE_DIR=./downloads/.vidflow
TEMP_DIR=./downloads

# File Naming & yt-dlp
OUTPUT_TEMPLATE=%(title)s.%(ext)s
OUTPUT_TEMPLATE_CHAPTER=%(title)s - %(section_number)s %(section_title)s.%(ext)s
OUTPUT_TEMPLATE_PLAYLIST=%(playlist_title)s/%(title)s.%(ext)s
YTDL_OPTIONS={}
YTDL_OPTIONS_FILE=

# yt-dlp Authentication (fixes YouTube 429/bot detection errors)
# Browser to extract cookies from: chrome, firefox, edge, brave, opera, safari, chromium
# Leave empty to disable cookie extraction
COOKIES_FROM_BROWSER=
# Or provide a path to a Netscape-format cookies file
COOKIES_FILE=

# Web Server & URLs
HOST=0.0.0.0
PORT=8081
URL_PREFIX=/
PUBLIC_HOST_URL=download/
PUBLIC_HOST_AUDIO_URL=audio_download/
HTTPS=false
CERTFILE=
KEYFILE=
ROBOTS_TXT=

# Basic Setup
UID=1000
GID=1000
UMASK=022
DEFAULT_THEME=auto
LOGLEVEL=INFO
ENABLE_ACCESSLOG=false
