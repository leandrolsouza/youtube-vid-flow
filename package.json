{
  "name": "vidflow-nodejs",
  "version": "1.0.0",
  "description": "Modern video downloader powered by yt-dlp - Node.js backend",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "node test-server.js",
    "build:ui": "cd ui && npm install && npm run build",
    "local": "start-local.bat",
    "docker:build": "docker build -f Dockerfile.nodejs -t vidflow-nodejs .",
    "docker:run": "docker-compose -f docker-compose.nodejs.yml up -d",
    "docker:stop": "docker-compose -f docker-compose.nodejs.yml down"
  },
  "keywords": [
    "youtube-dl",
    "yt-dlp",
    "downloader",
    "video"
  ],
  "author": "",
  "license": "AGPL-3.0",
  "dependencies": {
    "chokidar": "^5.0.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "lowdb": "^7.0.1",
    "npm-check-updates": "^20.0.0",
    "socket.io": "^4.8.3",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "node-fetch": "^3.3.2",
    "nodemon": "^3.1.14"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
